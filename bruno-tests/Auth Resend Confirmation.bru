meta {
  name: Auth Resend Confirmation
  type: http
  seq: 6
}

post {
  url: {{baseUrl}}/api/auth/resend-confirmation
  body: json
  auth: none
}

body:json {
  {
    "email": "test@example.com"
  }
}

vars:pre-request {
  baseUrl: http://localhost:8001
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.message: contains "Confirmation code resent"
}

tests {
  test("Should resend confirmation code", function() {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody().success).to.be.true;
    expect(res.getBody().message).to.contain("Confirmation code resent");
  });
}
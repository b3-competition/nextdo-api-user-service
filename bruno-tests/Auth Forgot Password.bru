meta {
  name: Auth Forgot Password
  type: http
  seq: 4
}

post {
  url: {{baseUrl}}/api/v1/auth/forgot-password
  body: json
  auth: none
}

body:json {
  {
    "email": "test@example.com"
  }
}

vars:pre-request {
  baseUrl: http://localhost:8001
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.message: contains "Password reset code sent"
}

tests {
  test("Should initiate forgot password flow", function() {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody().success).to.be.true;
    expect(res.getBody().message).to.contain("Password reset code sent");
  });
}
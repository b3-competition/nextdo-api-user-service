meta {
  name: Auth Verify Token
  type: http
  seq: 7
}

get {
  url: {{baseUrl}}/api/v1/auth/verify-token
  body: none
  auth: bearer
}

auth:bearer {
  token: {{accessToken}}
}

vars:pre-request {
  baseUrl: http://localhost:8001
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.message: eq "Token is valid"
  res.body.payload: isDefined
}

tests {
  test("Should verify token successfully", function() {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody().success).to.be.true;
    expect(res.getBody().message).to.equal("Token is valid");
    expect(res.getBody().payload).to.be.an('object');
  });
}
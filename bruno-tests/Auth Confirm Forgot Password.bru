meta {
  name: Auth Confirm Forgot Password
  type: http
  seq: 5
}

post {
  url: {{baseUrl}}/api/auth/confirm-forgot-password
  body: json
  auth: none
}

body:json {
  {
    "email": "test@example.com",
    "confirmationCode": "123456",
    "newPassword": "NewPassword123!"
  }
}

vars:pre-request {
  baseUrl: http://localhost:8001
}

assert {
  res.status: eq 200
  res.body.success: eq true
  res.body.message: contains "Password reset successfully"
}

tests {
  test("Should confirm forgot password", function() {
    expect(res.getStatus()).to.equal(200);
    expect(res.getBody().success).to.be.true;
    expect(res.getBody().message).to.contain("Password reset successfully");
  });
}
meta {
  name: Auth Signup
  type: http
  seq: 1
}

post {
  url: {{baseUrl}}/api/v1/auth/signup
  body: json
  auth: none
}

body:json {
  {
    "email": "test@example.com",
    "password": "TestPassword123!",
    "firstName": "John",
    "lastName": "Doe"
  }
}

vars:pre-request {
  baseUrl: http://localhost:8001
}

assert {
  res.status: eq 201
  res.body.success: eq true
  res.body.message: contains "User registered successfully"
  res.body.userSub: isDefined
}

tests {
  test("Should create user successfully", function() {
    expect(res.getStatus()).to.equal(201);
    expect(res.getBody().success).to.be.true;
    expect(res.getBody().message).to.contain("User registered successfully");
    expect(res.getBody().userSub).to.be.a('string');
  });
}
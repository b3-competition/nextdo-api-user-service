# Server Configuration
PORT=8001
API_VERSION=1

# AWS Configuration
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key_here
AWS_SECRET_ACCESS_KEY=your_secret_key_here

# AWS Cognito Configuration
COGNITO_USER_POOL_ID=your_user_pool_id_here
COGNITO_CLIENT_ID=your_client_id_here
COGNITO_CLIENT_SECRET=your_client_secret_here

# Production Environment (optional)
NODE_ENV=development
ALLOWED_ORIGINS=https://yourdomain.com,https://app.yourdomain.com

# Note: User Pool configuration requirements:
# - Region must match AWS_REGION
# - User Pool ID from AWS Cognito console
# - Client ID from your application
# - Authentication Flow: USER_PASSWORD_AUTH must be enabled